generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mysql"
}

enum SenderType {
  USER
  REFUGE
}

model UserProfile {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String?
  phone        String?
  name         String?
  location     String?
  latitude     Float?
  longitude    Float?
  searchRadius Int      @default(30)
  hasGarden    Boolean  @default(false)
  hasChildren  Boolean  @default(false)
  hasOtherPets Boolean  @default(false)
  timeFree     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  adoptions Adoption[]

  @@index([latitude, longitude])
}

model Adoption {
  id               Int         @id @default(autoincrement())
  userId           Int
  user             UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  animalExternalId String
  animalName       String
  animalImage      String?

  refugeId Int?
  refuge   Refuge? @relation(fields: [refugeId], references: [id]) // CORRECTION

  status          String    @default("pending") // Peut être passé en Enum
  hasUnreadUser   Boolean   @default(false)
  hasUnreadRefuge Boolean   @default(false)
  messages        Message[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Message {
  id         Int        @id @default(autoincrement())
  adoptionId Int
  adoption   Adoption   @relation(fields: [adoptionId], references: [id], onDelete: Cascade)
  senderType SenderType // CORRECTION (Enum)
  senderId   Int
  content    String     @db.Text
  createdAt  DateTime   @default(now())

  @@index([adoptionId])
}

model Refuge {
  id               Int     @id @default(autoincrement())
  name             String
  description      String? @db.Text
  address          String
  city             String
  postalCode       String
  latitude         Float
  longitude        Float
  phone            String?
  email_refuge     String  @unique
  website          String?
  password         String?
  verificationCode String?
  isVerified       Boolean @default(false)

  animals   Animal[]
  adoptions Adoption[] // CORRECTION

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([latitude, longitude])
}

model Animal {
  id          Int     @id @default(autoincrement())
  externalId  String  @unique
  name        String
  species     String
  breed       String?
  age         String?
  gender      String?
  size        String?
  description String? @db.Text
  photos      Json?

  goodWithChildren Boolean @default(false)
  goodWithDogs     Boolean @default(false)
  goodWithCats     Boolean @default(false)
  needsGarden      Boolean @default(false)
  energyLevel      String?

  refugeId Int
  refuge   Refuge @relation(fields: [refugeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([species, breed])
}
